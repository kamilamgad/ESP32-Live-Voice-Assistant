PCM_SAMPLE_RATE=16000
PCM_CHANNELS=1
WAKE_WINDOW_SECONDS=2.5
WAKE_CHECK_INTERVAL_SECONDS=1.0
COMMAND_MAX_SECONDS=12
COMMAND_MIN_SECONDS=0.7
COMMAND_SILENCE_SECONDS=0.9
VAD_ENERGY_THRESHOLD=1300
